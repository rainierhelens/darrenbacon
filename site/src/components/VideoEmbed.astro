---
interface Props {
  title: string;
  description?: string;
  youtubeId: string;
  url: string;
  featured?: boolean;
}

const { title, description, youtubeId, url, featured = false } = Astro.props;
---

<div class:list={['overflow-hidden rounded-2xl border bg-bg', featured ? 'border-accent/40' : 'border-border/60']}>
  <div class="aspect-video">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
      title={title}
      class="h-full w-full"
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    />
  </div>
  <div class="border-t border-border/60 px-5 py-4">
    <h3 class:list={['font-medium', featured && 'text-lg']}>{title}</h3>
    {description && <p class="mt-2 text-sm leading-relaxed text-muted">{description}</p>}
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-3 inline-flex text-sm text-accent transition hover:text-fg"
    >
      Watch on YouTube →
    </a>
  </div>
</div>
