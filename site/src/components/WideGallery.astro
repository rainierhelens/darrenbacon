---
interface Props {
  images: { src: string; caption?: string }[];
  altPrefix?: string;
  groupId?: string;
}

const {
  images,
  altPrefix = 'Artwork',
  groupId = `wide-${images.length}-${images[0]?.src.slice(-20).replace(/\W/g, '') ?? 'gallery'}`,
} = Astro.props;
---

<section class="w-full" data-lightbox-group={groupId}>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    {
      images.map((image, index) => (
        <figure class="overflow-hidden rounded-2xl border border-border/60 bg-surface">
          <button
            type="button"
            class="group block w-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
            data-lightbox-item
            data-group={groupId}
            data-index={index}
            data-src={image.src}
            data-caption={image.caption}
            aria-label={image.caption ?? `Open image ${index + 1}`}
          >
            <img
              src={image.src}
              alt={image.caption ?? `${altPrefix} ${index + 1}`}
              loading="lazy"
              decoding="async"
              draggable="false"
              class="pointer-events-none w-full object-contain transition duration-500 group-hover:opacity-90"
            />
          </button>
          {image.caption && (
            <figcaption class="border-t border-border/60 px-4 py-3 text-sm text-muted">
              {image.caption}
            </figcaption>
          )}
        </figure>
      ))
    }
  </div>
</section>
