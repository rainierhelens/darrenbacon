---
import { site, socialLinks } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-border/60 bg-surface">
  <div class="mx-auto flex max-w-7xl flex-col gap-8 px-6 py-12 lg:px-8">
    <div class="flex flex-col justify-between gap-6 md:flex-row md:items-end">
      <div>
        <p class="text-lg font-semibold tracking-wide">{site.name}</p>
        <p class="mt-1 text-sm text-muted">{site.tagline}</p>
      </div>
      <div class="flex flex-wrap gap-x-6 gap-y-2">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-muted transition-colors hover:text-accent"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
    <div class="flex flex-col gap-2 border-t border-border/60 pt-6 text-sm text-muted sm:flex-row sm:justify-between">
      <p>&copy; {site.name}, {year}</p>
      <a href={`mailto:${site.email}`} class="transition-colors hover:text-fg">{site.email}</a>
    </div>
  </div>
</footer>
