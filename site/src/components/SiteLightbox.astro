  </button>
  <img id="site-lightbox-image" src="" alt="" class="max-h-[90vh] max-w-[95vw] object-contain" />
  <p id="site-lightbox-caption" class="absolute bottom-12 hidden max-w-2xl px-4 text-center text-sm text-muted"></p>
