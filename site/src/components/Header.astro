---
import { nav, site, socialLinks } from '../data/site';

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border/60 bg-bg/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <a href="/" class="group flex flex-col gap-0.5">
      <span class="text-sm font-semibold tracking-[0.2em] uppercase text-fg transition-colors group-hover:text-accent">
        {site.name}
      </span>
      <span class="text-xs text-muted">{site.tagline}</span>
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Main navigation">
      {
        nav.map((item) => {
          const isActive =
            currentPath === item.href ||
            (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <a
              href={item.href}
              class:list={[
                'text-sm tracking-wide uppercase transition-colors',
                isActive ? 'text-accent' : 'text-muted hover:text-fg',
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <a
      href={socialLinks[1].href}
      target="_blank"
      rel="noopener noreferrer"
      class="hidden text-sm text-muted transition-colors hover:text-accent sm:inline"
    >
      {site.handle}
    </a>

    <button
      id="mobile-menu-btn"
      type="button"
      class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-border text-fg md:hidden"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-border/60 bg-surface px-6 py-4 md:hidden"
    aria-label="Mobile navigation"
  >
    <div class="flex flex-col gap-4">
      {
        nav.map((item) => (
          <a href={item.href} class="text-sm tracking-wide uppercase text-muted transition-colors hover:text-fg">
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });
</script>
